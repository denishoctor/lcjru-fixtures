(function () {
  var root = document.getElementById('lcjru-cal');
  if (!root) return;
  var rows = [].slice.call(root.querySelectorAll('tbody tr')).filter(function (r) {
    return !r.classList.contains('lcjru-head') && !r.classList.contains('lcjru-empty');
  });
  var empty = root.querySelector('.lcjru-empty');
  var aud = 'all', type = 'all';

  function apply() {
    var shown = 0;
    rows.forEach(function (r) {
      var ra = r.getAttribute('data-aud') || 'all';
      var rt = r.getAttribute('data-type') || 'event';
      var audOk = (aud === 'all') || (ra === 'all') || (ra === aud);
      var typeOk = (type === 'all') || (rt === type);
      var show = audOk && typeOk;
      r.style.display = show ? '' : 'none';
      if (show) { r.classList.toggle('zebra', shown % 2 === 1); shown++; }
      else { r.classList.remove('zebra'); }
    });
    if (empty) empty.style.display = shown ? 'none' : '';
  }

  [].slice.call(root.querySelectorAll('.lcjru-pill')).forEach(function (btn) {
    btn.addEventListener('click', function () {
      var group = btn.hasAttribute('data-aud') ? 'aud' : 'type';
      var val = btn.getAttribute('data-' + group);
      if (group === 'aud') aud = val; else type = val;
      [].slice.call(root.querySelectorAll('.lcjru-pill[data-' + group + ']')).forEach(function (b) {
        var on = (b === btn);
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      apply();
    });
  });

  apply();
})();
</script><h3>MINIS DRAW</h3><p>Minis play on Sundays in 2026, with venues for U6/U7 and U8/U9 listed round-by-round in the calendar above. Watch your team WhatsApp for week-of confirmations and KO times, or speak to your Team Manager or Age Coordinator if anything is unclear.</p><h3>JUNIORS DRAW</h3><p>Juniors will play on Sundays as in previous seasons. Comms will be managed through WhatsApp. Please talk to your Team Manager or Age Coordinator for access. You'll find scores and other details on the <a data-link='{"new_window":true,"type":"external","url":"https://xplorer.rugby/lcjru-/fixtures-results?team=All&comp=All&season=All&tab=Fixtures"}'>LCJRU Fixtures page</a> via Rugby Xplorer.</p><h3>CLUB SOCIAL — THE LONG LUNCH</h3><p>The biggest day of the year on the LCJRU calendar returns on <strong>Friday 31 July from 12:30pm at Dockside, Cockle Bay Wharf</strong>. The Long Lunch is our club's social event of the year and our biggest fundraiser for the U14s' tour to New Zealand — a tradition open to every U14 player, with potentially no cost to families if our fundraising goes well. It's a sit-down lunch with famous former players, a raffle and an auction. Tickets are <strong>$160 per person</strong> — significantly cheaper than last year, and expected to sell out — so please save the date and bring as many people from your age group as you can. If you can donate a raffle or auction prize, email <a href="mailto:president@lcjru.com.au">president@lcjru.com.au</a>.</p><h2>club code of conduct</h2><ul><li style="box-sizing: border-box; outline: 0px; color: rgb(0, 0, 0); font-family: Roboto, Arial; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;"><a data-link='{"type":"file","id":"6a846d93-4ef7-4e26-839e-12004e524e30","new_window":true}'>LCJRU Club code of conduct for players and parents</a></li></ul><h2>SJRU COMPETITION RULES &amp; MATCH DAY MANUAL&nbsp;</h2><ul><li><a data-link='{"type":"file","id":"00a720c4-1899-4e00-b0bb-b5ec2747ffef","new_window":true}'>SJRU Match Day Manual&nbsp;</a></li><li><a data-link='{"type":"file","id":"19a2bbbc-e2a2-41ae-bd46-4056f4c6c6f6","new_window":true}'>Scrum Mayday Call and Procedure</a></li></ul><h2>rugby xplorer and match day app</h2><ul><li><a data-link='{"new_window":true,"type":"external","url":"https://australia.rugby/participate/rugby-administration/club-administration/resource-library"}'>Rugby Xplorer Help pages</a></li><li><a data-link='{"new_window":true,"type":"external","url":"https://myaccount.rugbyxplorer.com.au/dashboard"}'>Rugby Xplorer Portal</a></li><li><a data-link='{"new_window":true,"type":"external","url":"https://help.australia.rugby/s/"}'>Rugby Xplorer Help desk</a></li></ul>